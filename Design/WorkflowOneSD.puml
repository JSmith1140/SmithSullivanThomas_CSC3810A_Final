@startuml Workflow One Sequence Diagram
title Workflow One: User Creates Playlist

actor User
participant "GUI (Presentation Layer)" as GUI
participant "PlaylistController (BLL)" as BLL
participant "PlaylistDataProvider (DAL)" as DAL
participant "Database" as DB

User -> GUI : Enter UserId, PlaylistName
GUI -> BLL : createPlaylist(userId, playlistName)

BLL -> DAL : createPlaylist(userId, playlistName)

DAL -> DB : CALL CreatePlaylist(userId, playlistName)

DB --> DAL : return playlistId

DAL --> BLL : playlistId
BLL --> GUI : playlistId

GUI --> User : "Playlist created successfully"

@enduml